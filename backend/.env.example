# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL (matches docker-compose defaults)
POSTGRES_USER=charon
POSTGRES_PASSWORD=charon_password
POSTGRES_DB=charon_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://charon:charon_password@localhost:5432/charon_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Privy (Dashboard → Settings → Basics)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
# Optional: paste verification key from Dashboard to skip runtime fetch
# PRIVY_JWT_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# API security
API_KEY=dev-api-key-change-me
SECRET_KEY=dev-secret-change-me

# Blockchain (optional — for listener)
RPC_URL=
CHARON_SWITCH_ADDRESS=

# OpenAI (optional — for agent execution)
OPENAI_API_KEY=

# IPFS (optional)
PINATA_API_KEY=
PINATA_SECRET_KEY=
